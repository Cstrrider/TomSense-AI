# TomSense configuration — `bash setup.sh` generates .env for you (secrets,
# account, owner email, localhost/domain mode). This file documents the
# optional knobs you can add to .env afterwards. Full list with defaults:
# backend/app/config.py.

# ── written by setup.sh (required) ──────────────────────────────────────
# CF_ACCOUNT_ID=
# CF_API_TOKEN=
# TOMSENSE_OWNER_EMAIL=you@example.com
# REQUIRE_CF_ACCESS=0|1
# TOMSENSE_DB_PASSWORD=…      SANDBOX_TOKEN=…      JUPYTER_TOKEN=…
# MCP_SERVER_KEY=…            TOMSENSE_ENCRYPTION_KEY=…

# ── ports ───────────────────────────────────────────────────────────────
# TOMSENSE_PORT=8002          # frontend (the page you open)
# TOMSENSE_API_PORT=8001      # backend API (MCP server, dev)

# ── models (defaults shown; any @cf/* Workers AI model id works) ────────
# MODEL_CHAT=@cf/google/gemma-4-26b-a4b-it
# MODEL_CODER=@cf/google/gemma-4-26b-a4b-it
# MODEL_WRITER=@cf/openai/gpt-oss-120b
# MODEL_RESEARCH=@cf/openai/gpt-oss-120b
# MODEL_IMAGE_SD=@cf/black-forest-labs/flux-2-klein-4b
# MODEL_IMAGE_HD=@cf/black-forest-labs/flux-2-klein-9b

# ── optional providers ──────────────────────────────────────────────────
# ANTHROPIC_API_KEY=          # enables Claude entries in the code-mode picker
# CF_AIG_TOKEN=               # AI Gateway token for premium image models
# CF_GATEWAY_ID=default

# ── push notifications (ntfy.sh app; subscribe to your secret topic) ────
# NTFY_TOPIC=tomsense-<random>
# NTFY_URL=https://ntfy.sh
# NTFY_TOKEN=

# ── reuse existing sidecars instead of the bundled ones ─────────────────
# SEARXNG_URL=  JUPYTER_URL=  WHISPER_URL=  PIPER_URL=  QDRANT_URL=

# ── budgets / behavior (see config.py for many more) ────────────────────
# CF_DAILY_NEURON_LIMIT=10000   # raise if you're on a paid Workers AI plan
# NEURON_SOFT_CAP_PCT=80        # budget-mode downshift threshold (0 = off)
# FIRST_TOKEN_TIMEOUT_S=45      # stall guard → STALL_FALLBACK_MODEL
# STALL_FALLBACK_MODEL=@cf/openai/gpt-oss-120b
# SCHEDULE_TZ=America/New_York  # tz for scheduled prompts
